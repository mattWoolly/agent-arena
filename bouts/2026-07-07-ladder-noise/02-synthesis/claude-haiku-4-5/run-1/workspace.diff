+        return False
+
+    if len(cleaned) == 1:
+        return cleaned == "0"
+
+    digits = [int(d) for d in cleaned]
+    total = 0
+
+    for i, digit in enumerate(reversed(digits)):
+        if i % 2 == 1:
+            digit *= 2
+            if digit > 9:
+                digit -= 9
+        total += digit
+
+    return total % 10 == 0
 
 
