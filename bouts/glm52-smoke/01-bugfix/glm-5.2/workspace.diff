@@ -27,10 +27,13 @@ class LRUCache:
         if self.ttl is not None and self._clock() - ts > self.ttl:
             del self._data[key]
             return default
+        self._data.move_to_end(key)  # a read counts as a use
         return value
 
     def put(self, key, value):
-        if len(self._data) >= self.capacity:
+        # Only evict when adding a brand-new key beyond capacity; updating an
+        # existing key in place must not change the entry count.
