 def luhn_valid(number):
@@ -26,7 +39,22 @@ def luhn_valid(number):
     spaces and hyphens, the string is empty or contains any non-digit
     character. A single digit "0" is valid; any other single digit is not.
     """
-    raise NotImplementedError
+    if not isinstance(number, str):
+        return False
+
+    digits = number.replace(" ", "").replace("-", "")
+    if not digits or any(digit < "0" or digit > "9" for digit in digits):
+        return False
+
+    total = 0
+    for index, digit in enumerate(reversed(digits)):
+        value = int(digit)
+        if index % 2 == 1:
+            value *= 2
+            if value > 9:
+                value -= 9
+        total += value
+    return total % 10 == 0
 
 
