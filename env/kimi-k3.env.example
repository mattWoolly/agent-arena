# Per-model environment for kimi-k3 (Moonshot AI) via Moonshot's
# Anthropic-compatible endpoint. Copy to env/kimi-k3.env and fill in the key.
# The real .env file is gitignored; never commit keys.
#
# Docs: https://platform.kimi.ai/docs/guide/claude-code-kimi
ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
ANTHROPIC_AUTH_TOKEN=sk-REPLACE_ME
# Pin every internal model slot to kimi-k3 so no side-channel calls
# (subagents, background summarization) leak to a different vendor/model.
ANTHROPIC_MODEL=kimi-k3
ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-k3
ANTHROPIC_DEFAULT_SONNET_MODEL=kimi-k3
ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-k3
CLAUDE_CODE_SUBAGENT_MODEL=kimi-k3
