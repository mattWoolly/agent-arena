# gpt-5.6-sol (OpenAI) via a local LiteLLM translation proxy.
# Copy to env/gpt-5.6-sol.env. Start the proxy before any run:
#   bin/arena-proxy.sh start gpt-5.6-sol
#
# The OpenAI key is deliberately NOT in this file and never enters the
# contestant's environment; only the proxy process holds it. The token below
# is a dummy the localhost proxy ignores. env/gpt-5.6-sol.leakscan gives the
# post-run leak check the real key value to scan published artifacts for.
ANTHROPIC_BASE_URL=http://127.0.0.1:4100
ANTHROPIC_AUTH_TOKEN=sk-local-arena-proxy
# Pin every internal model slot so no side-channel calls reach a different
# vendor or model.
ANTHROPIC_MODEL=gpt-5.6-sol
ANTHROPIC_DEFAULT_OPUS_MODEL=gpt-5.6-sol
ANTHROPIC_DEFAULT_SONNET_MODEL=gpt-5.6-sol
ANTHROPIC_DEFAULT_HAIKU_MODEL=gpt-5.6-sol
CLAUDE_CODE_SUBAGENT_MODEL=gpt-5.6-sol
# Recorded verbatim in run_env.json: what actually sits behind localhost.
ARENA_PROXY_UPSTREAM="openai/gpt-5.6-sol via litellm 1.92.0 (local translation proxy)"
