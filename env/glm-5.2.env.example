# Per-model environment for glm-5.2 (Zhipu / Z.ai) via Z.ai's
# Anthropic-compatible endpoint. Copy to env/glm-5.2.env and fill in the key.
# The real .env file is gitignored; never commit keys.
#
# Docs: https://docs.z.ai/scenario-example/develop-tools/claude
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=REPLACE_ME
# Pin every internal model slot to glm-5.2 so no side-channel calls
# (subagents, background summarization) leak to a different vendor/model.
ANTHROPIC_MODEL=glm-5.2
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.2
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5.2
CLAUDE_CODE_SUBAGENT_MODEL=glm-5.2
